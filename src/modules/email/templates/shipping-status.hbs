<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: Arial, sans-serif; color: #333; line-height: 1.6; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; background-color: #f9f9f9; }
    .header { background-color: #3498db; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }
    .content { background-color: white; padding: 20px; }
    .status-box { background-color: #ecf0f1; padding: 15px; border-radius: 5px; margin: 20px 0; }
    .status-badge { display: inline-block; padding: 8px 15px; background-color: #3498db; color: white; border-radius: 3px; font-weight: bold; }
    .details { margin: 15px 0; }
    .detail-row { padding: 8px 0; }
    .button { display: inline-block; padding: 12px 24px; background-color: #27ae60; color: white; text-decoration: none; border-radius: 5px; margin: 15px 0; }
    .footer { background-color: #f9f9f9; padding: 15px; text-align: center; font-size: 12px; color: #777; border-radius: 0 0 5px 5px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>📦 Shipping Status Update</h1>
    </div>
    <div class="content">
      <p>Hi {{customerName}},</p>
      <p>Your package has a new update!</p>
      
      <div class="status-box">
        <div class="detail-row">
          <span class="status-badge">{{statusMessage}}</span>
        </div>
        <div class="details">
          <div class="detail-row">
            <strong>Tracking Number:</strong> {{trackingNumber}}
          </div>
          <div class="detail-row">
            <strong>Order Number:</strong> #{{orderNumber}}
          </div>
          <div class="detail-row">
            <strong>Courier:</strong> {{courierName}}
          </div>
          <div class="detail-row">
            <strong>Current Location:</strong> {{location}}
          </div>
          {{#if estimatedDelivery}}
            <div class="detail-row">
              <strong>Estimated Delivery:</strong> {{estimatedDelivery}}
            </div>
          {{/if}}
        </div>
      </div>
      
      <p><a href="{{trackingUrl}}" class="button">View Full Tracking Details</a></p>
      
      {{#if status 'out_for_delivery'}}
        <p><strong>Your package is arriving today!</strong></p>
        <p>Please ensure someone is available to receive it. If you're not home, contact the courier or update delivery instructions.</p>
      {{/if}}
      
      <p>If you have any questions or concerns, please <a href="https://dentalkart.com/support">contact our support team</a>.</p>
      
      <p>Thank you,<br><strong>DentalKart Team</strong></p>
    </div>
    <div class="footer">
      <p>&copy; {{year}} DentalKart. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
